  "conventions": {
    "ticket_id_format": "<Project Code>-<zero-padded number>",
    "child_db_naming": "<Serialized ID>-<Purpose>",
    "child_db_required_props": [
      "Name (title)",
      "Source Ticket (relation to tickets)",
      "Status (select: Pending/Complete/Error)",
      "Created Date (created_time)"
    ],
    "child_db_placement": "nested under originating ticket page",
    "error_handling": {
      "max_retries": 3,
      "on_error": "log as comment on source ticket with ISO 8601 timestamp",
      "on_blocking_error": "set ticket Status to Blocked",
      "never": "modify or delete existing data to recover"
    }
  },
  "workflows": {
    "client_request": "Create ticket -> Triage -> Spawn tasks -> Execute -> Done",
    "initiative_approval": "Update initiative -> Create project -> Add project code -> Create tickets -> Spawn tasks",
    "client_onboarding": "Update client to Closed Won -> Create engagement -> Create project code -> Create onboarding tickets",
    "agent_autonomous": "Create ticket (Source=Agent) -> In Progress -> Create child DB -> Do work -> Summary comment -> Done",
    "periodic_review": "Query all DBs -> Flag stale items -> Create summary ticket",
    "data_migration": "Scan source teamspace -> Map schema -> Plan batches -> Execute with approval -> Summary ticket -> Update config",
    "incremental_sync": "Load migration config -> Query source for changes since last_synced_at -> Present new/modified records -> Execute approved changes -> Update last_synced_at",
    "effort_logging": "Set Effort Estimate -> Auto-populate Hours Estimated -> Complete task -> Log Hours Spent -> Variance comment",
    "health_check": "Run enabled alert checks -> Group by severity -> Present summary -> Auto-ticket critical items -> Offer actions",
    "capacity_check": "Calculate per-user load -> Compare to sprint capacity -> Flag overloaded -> Suggest rebalancing",
    "morning_briefing_v2": "Run health checks -> Alert summary -> In progress items -> Blocked items -> Due dates -> Capacity snapshot"
  },
  "migrations": {
    "sources": []
  },
  "effort": {
    "hours_mapping": {
      "XS": 1,
      "S": 2,
      "M": 4,
      "L": 8,
      "XL": 16
    },
    "prompt_on_completion": true,
    "track_variance": true,
    "default_log_unit": "hours"
  },
  "alerts": {
    "enabled": true,
    "run_on_briefing": true,
    "auto_ticket_on_critical": true,
    "checks": {
      "stale_tickets": {
        "enabled": true,
        "threshold_days": 7,
        "severity": "warning"
      },
      "stale_critical_tickets": {
        "enabled": true,
        "threshold_hours": 24,
        "severity": "critical",
        "applies_to": [
          "P0"
        ]
      },
      "stale_high_tickets": {
        "enabled": true,
        "threshold_days": 3,
        "severity": "warning",
        "applies_to": [
          "P1"
        ]
      },
      "overloaded_assignees": {
        "enabled": true,
        "max_open_tasks": 8,
        "severity": "warning"
      },
      "orphan_tasks": {
        "enabled": true,
        "severity": "info"
      },
      "unassigned_work": {
        "enabled": true,
        "severity": "warning",
        "min_status": "Triaged"
      },
      "empty_engagements": {
        "enabled": true,
        "threshold_days": 30,
        "severity": "warning"
      },
      "upcoming_deadlines": {
        "enabled": true,
        "lookahead_days": 3,
        "severity": "info"
      },
      "sprint_overflow": {
        "enabled": true,
        "severity": "warning",
        "requires": "capacity"
      },
      "effort_variance": {
        "enabled": true,
        "threshold_percentage": 50,
        "severity": "info",
        "requires": "effort"
      }
    }
  },
  "capacity": {
    "enabled": true,
    "sprint_duration_weeks": 2,
    "default_hours_per_sprint": 30,
    "warning_threshold_percent": 80,
    "users": {},
    "assignment_guard": true
  }
